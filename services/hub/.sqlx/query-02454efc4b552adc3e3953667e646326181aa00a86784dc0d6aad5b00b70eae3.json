{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, email, name, status as \"status!\", subscribed_at\n        FROM subscriptions\n        WHERE ($1::TEXT IS NULL OR status = $1)\n          AND ($2::TEXT IS NULL OR email ILIKE $2 OR name ILIKE $2)\n        ORDER BY subscribed_at DESC\n        LIMIT $3 OFFSET $4\n        ",
