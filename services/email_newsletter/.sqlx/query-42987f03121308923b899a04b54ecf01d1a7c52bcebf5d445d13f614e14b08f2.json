{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            d.newsletter_issue_id,\n            n.title as \"newsletter_title?\",\n            d.subscriber_email,\n            d.attempt_count,\n            d.last_error,\n            d.failed_at\n        FROM dead_letter_queue d\n        LEFT JOIN newsletter_issues n ON n.newsletter_issue_id = d.newsletter_issue_id\n        ORDER BY d.failed_at DESC\n        ",
